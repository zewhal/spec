# MiniMax/OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.minimax.io/v1
OPENAI_API_KEY=replace_with_real_key

# Optional CLI defaults for LLM mode
# SPEC_LLM_MODEL=MiniMax-M2.5
# AHENTE_LLM_MODEL=MiniMax-M2.5

# ===========================================
# Test credentials - copy to .env and fill in
# NEVER commit .env with real credentials
# ===========================================

# Test user credentials
TEST_EMAIL=replace_with_test_email
TEST_PASSWORD=replace_with_test_password

# Admin credentials (for setup/teardown tests)
ADMIN_EMAIL=replace_with_admin_email
ADMIN_PASSWORD=replace_with_admin_password
